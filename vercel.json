{
    "functions": {
        "public/**/*.php": {
            "runtime": "vercel-php@0.7.0"
        },
        "src/**/*.php": {
            "runtime": "vercel-php@0.7.0"
        }
    },
    "routes": [
        {
            "src": "/",
            "dest": "/public/login.php"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}